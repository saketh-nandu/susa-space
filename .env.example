# ─────────────────────────────────────────────────────
# SUSA Space — Environment Variables
# Copy this file to .env and fill in your real values.
# Never commit .env to source control.
# ─────────────────────────────────────────────────────

# ── Gemini AI (server-side only) ─────────────────────
# Required for AI assistant, note summarizer, and recap endpoints.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# ── App URL ───────────────────────────────────────────
# The URL where this app is hosted (used for OAuth callbacks, etc.)
# AI Studio automatically injects this with the Cloud Run service URL.
APP_URL="http://localhost:3000"

# ── Firebase ──────────────────────────────────────────
# Credentials for Firebase Authentication + Firestore real-time sync.
# Get these from your Firebase project → Project Settings → Your Apps.
VITE_FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="YOUR_PROJECT_ID.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="YOUR_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="YOUR_PROJECT_ID.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="YOUR_MESSAGING_SENDER_ID"
VITE_FIREBASE_APP_ID="YOUR_FIREBASE_APP_ID"
# Custom Firestore database ID (leave as "(default)" for the default database)
VITE_FIREBASE_DATABASE_ID="(default)"

# ── Supabase ──────────────────────────────────────────
# Credentials for Supabase Storage buckets (media, photos, voice notes).
# Get these from your Supabase project → Settings → API.
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
# The storage bucket name to use for Orbit media uploads
VITE_SUPABASE_BUCKET="orbit-media"

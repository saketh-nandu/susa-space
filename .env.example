# ─────────────────────────────────────────────────────
# SUSA Space — Environment Variables
# Copy this file to .env and fill in your real values.
# Never commit .env to source control.
# ─────────────────────────────────────────────────────

# ── Gemini AI (server-side only) ─────────────────────
# Required for AI assistant, note summarizer, and recap endpoints.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# ── App URL ───────────────────────────────────────────
# The URL where this app is hosted (used for OAuth callbacks, etc.)
# AI Studio automatically injects this with the Cloud Run service URL.
APP_URL="http://localhost:3000"

# ── Appwrite ──────────────────────────────────────────
# Credentials for Appwrite Authentication, Database, Storage, and Hosting.
# Get these from your Appwrite project → Project Settings.
VITE_APPWRITE_ENDPOINT="https://cloud.appwrite.io/v1"
VITE_APPWRITE_PROJECT_ID="YOUR_APPWRITE_PROJECT_ID"
VITE_APPWRITE_DATABASE_ID="YOUR_APPWRITE_DATABASE_ID"
VITE_APPWRITE_BUCKET_ID="YOUR_APPWRITE_BUCKET_ID"
